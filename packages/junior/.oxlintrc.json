{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "eslint",
    "typescript",
    "unicorn",
    "oxc",
    "import",
    "node",
    "vitest"
  ],
  "ignorePatterns": ["dist/**"],
  "rules": {
    "unicorn/no-useless-fallback-in-spread": "off",
    "vitest/hoisted-apis-on-top": "off",
    "vitest/require-mock-type-parameters": "off"
  }
}
