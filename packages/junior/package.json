{
  "name": "@sentry/junior",
  "version": "0.9.1",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "packageManager": "pnpm@10.30.2",
  "bin": {
    "junior": "bin/junior.mjs"
  },
  "exports": {
    "./handler": "./dist/handlers/router.js",
    "./handlers/webhooks": "./dist/handlers/webhooks.js",
    "./handlers/queue-callback": "./dist/handlers/queue-callback.js",
    "./handlers/health": "./dist/handlers/health.js",
    "./config": "./dist/next-config.js",
    "./instrumentation": "./dist/instrumentation.js",
    "./app/layout": "./dist/app/layout.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "prepare": "pnpm run build",
    "prepack": "pnpm run build",
    "build": "tsup",
    "test": "pnpm run test:slack-boundary && vitest run",
    "test:watch": "vitest",
    "test:slack-boundary": "node scripts/check-slack-test-boundary.mjs",
    "typecheck": "tsc --noEmit",
    "skills:check": "node scripts/check-skills.mjs"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.66",
    "@chat-adapter/slack": "4.20.2",
    "@chat-adapter/state-memory": "4.20.2",
    "@chat-adapter/state-redis": "4.20.2",
    "@mariozechner/pi-agent-core": "^0.59.0",
    "@mariozechner/pi-ai": "^0.59.0",
    "@modelcontextprotocol/sdk": "1.27.1",
    "@sinclair/typebox": "^0.34.48",
    "@slack/web-api": "^7.15.0",
    "@vercel/queue": "^0.1.4",
    "@vercel/sandbox": "^1.8.1",
    "ai": "^6.0.116",
    "bash-tool": "^1.3.15",
    "chat": "4.20.2",
    "just-bash": "^2.13.1",
    "node-html-markdown": "^2.0.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@sentry/nextjs": ">=10.0.0",
    "next": ">=15.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "devDependencies": {
    "@sentry/nextjs": "^10.44.0",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "msw": "^2.12.13",
    "next": "^16.1.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vercel": "^50.32.5",
    "vitest": "^4.1.0"
  }
}
