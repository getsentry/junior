{
  "name": "@sentry/junior",
  "version": "0.14.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "packageManager": "pnpm@10.30.2",
  "bin": {
    "junior": "bin/junior.mjs"
  },
  "exports": {
    ".": "./dist/app.js",
    "./instrumentation": "./dist/instrumentation.js",
    "./nitro": "./dist/nitro.js",
    "./vercel": "./dist/vercel.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "prepare": "pnpm run build",
    "prepack": "pnpm run build",
    "build": "tsup",
    "test": "pnpm run test:slack-boundary && vitest run",
    "test:watch": "vitest",
    "test:slack-boundary": "node scripts/check-slack-test-boundary.mjs",
    "typecheck": "tsc --noEmit",
    "skills:check": "node scripts/check-skills.mjs"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.83",
    "@chat-adapter/slack": "4.23.0",
    "@chat-adapter/state-memory": "4.23.0",
    "@chat-adapter/state-redis": "4.23.0",
    "@mariozechner/pi-agent-core": "0.59.0",
    "@mariozechner/pi-ai": "0.59.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@sinclair/typebox": "^0.34.49",
    "@slack/web-api": "^7.15.0",
    "@vercel/functions": "^3.4.3",
    "@vercel/sandbox": "^1.9.0",
    "ai": "^6.0.141",
    "bash-tool": "^1.3.15",
    "chat": "4.23.0",
    "hono": "^4.12.9",
    "just-bash": "^2.14.0",
    "node-html-markdown": "^2.0.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@sentry/node": ">=10.0.0"
  },
  "devDependencies": {
    "@sentry/node": "^10.46.0",
    "@types/node": "^25.5.0",
    "msw": "^2.12.14",
    "nitro": "3.0.260311-beta",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vercel": "^50.37.3",
    "vitest": "^4.1.2"
  }
}
