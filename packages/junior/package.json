{
  "name": "@sentry/junior",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "packageManager": "pnpm@10.30.2",
  "bin": {
    "junior": "bin/junior.mjs"
  },
  "exports": {
    "./handler": "./dist/handlers/router.js",
    "./handlers/webhooks": "./dist/handlers/webhooks.js",
    "./handlers/queue-callback": "./dist/handlers/queue-callback.js",
    "./handlers/health": "./dist/handlers/health.js",
    "./config": "./dist/next-config.js",
    "./instrumentation": "./dist/instrumentation.js",
    "./app/layout": "./dist/app/layout.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "prepare": "pnpm run build:pkg",
    "prepack": "pnpm run build:pkg",
    "dev": "next dev",
    "build": "next build",
    "build:pkg": "tsup",
    "start": "next start",
    "test": "pnpm run test:slack-boundary && vitest run",
    "test:watch": "vitest",
    "preevals": "pnpm run test:slack-boundary",
    "evals": "pnpm exec vitest run -c vitest.evals.config.ts",
    "test:slack-boundary": "node scripts/check-slack-test-boundary.mjs",
    "typecheck": "tsc --noEmit",
    "skills:check": "node scripts/check-skills.mjs"
  },
  "dependencies": {
    "@sentry/junior-github": "workspace:*",
    "@sentry/junior-sentry": "workspace:*",
    "@ai-sdk/gateway": "^3.0.57",
    "@chat-adapter/slack": "4.15.0",
    "@chat-adapter/state-memory": "4.15.0",
    "@chat-adapter/state-redis": "4.15.0",
    "@mariozechner/pi-agent-core": "^0.55.0",
    "@mariozechner/pi-ai": "^0.55.0",
    "@sinclair/typebox": "^0.34.48",
    "@slack/web-api": "^7.14.1",
    "@vercel/queue": "^0.1.3",
    "@vercel/sandbox": "^1.7.1",
    "ai": "^6.0.103",
    "bash-tool": "^1.3.15",
    "chat": "4.15.0",
    "just-bash": "^2.10.6",
    "node-html-markdown": "^2.0.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@sentry/nextjs": ">=10.0.0",
    "next": ">=15.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "devDependencies": {
    "@sentry/nextjs": "^10.40.0",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "msw": "^2.12.10",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vercel": "^50.23.2",
    "vitest": "^4.0.18",
    "vitest-evals": "^0.6.0"
  }
}
