{
  "functions": {
    "api/index.ts": {
      "maxDuration": 800,
      "includeFiles": [
        "app/**/*",
        "node_modules/@sentry/junior-agent-browser/**/*",
        "node_modules/@sentry/junior-github/**/*",
        "node_modules/@sentry/junior-notion/**/*",
        "node_modules/@sentry/junior-sentry/**/*"
      ]
    }
  },
  "rewrites": [{ "source": "/api/(.*)", "destination": "/api" }]
}
