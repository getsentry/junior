{
  "name": "junior-monorepo",
  "private": true,
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "dev": "pnpm --filter jr-sentry dev",
    "build": "pnpm --filter @sentry/junior build",
    "build:pkg": "pnpm --filter @sentry/junior build:pkg",
    "start": "pnpm --filter @sentry/junior start",
    "test": "pnpm run test:consumer-build && pnpm --filter @sentry/junior test",
    "test:consumer-build": "pnpm --filter @sentry/junior build:pkg && pnpm --filter jr-sentry build",
    "test:watch": "pnpm --filter @sentry/junior test:watch",
    "preevals": "pnpm --filter @sentry/junior preevals",
    "evals": "pnpm --filter @sentry/junior evals",
    "typecheck": "pnpm --filter @sentry/junior typecheck",
    "skills:check": "pnpm --filter @sentry/junior skills:check"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "vitest-evals>ai": ">=4",
        "vitest-evals>zod": ">=3"
      }
    },
    "patchedDependencies": {
      "@chat-adapter/slack": "packages/junior/patches/@chat-adapter__slack.patch"
    }
  }
}
