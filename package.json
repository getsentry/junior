{
  "name": "junior-monorepo",
  "private": true,
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "dev": "node scripts/dev-with-root-env.mjs",
    "build": "pnpm --filter @sentry/junior build",
    "build:pkg": "pnpm --filter @sentry/junior build:pkg",
    "docs:dev": "pnpm --filter @sentry/junior-docs dev",
    "docs:build": "pnpm --filter @sentry/junior-docs build",
    "docs:check": "pnpm --filter @sentry/junior-docs check",
    "start": "pnpm --filter @sentry/junior start",
    "test": "pnpm --filter @sentry/junior build:pkg && pnpm --filter @sentry/junior test",
    "test:watch": "pnpm --filter @sentry/junior test:watch",
    "preevals": "pnpm --filter @sentry/junior preevals",
    "evals": "pnpm --filter @sentry/junior evals",
    "typecheck": "pnpm --filter @sentry/junior typecheck",
    "skills:check": "pnpm --filter @sentry/junior skills:check"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "vitest-evals>ai": ">=4",
        "vitest-evals>zod": ">=3"
      }
    }
  },
  "devDependencies": {
    "agent-browser": "^0.16.3"
  }
}
